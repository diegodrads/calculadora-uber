{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "GRADLE_OPTS": "-Xmx6g -XX:MaxMetaspaceSize=1g"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "GRADLE_OPTS": "-Xmx6g -XX:MaxMetaspaceSize=1g"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
